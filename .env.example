# ============================================
# ParaBench - .env.example
# Copiez ce fichier en .env et configurez
# ============================================

# Base de données PostgreSQL
POSTGRES_DB=parabench
POSTGRES_USER=parabench
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# Backend sécurité
SECRET_KEY=CHANGE_ME_RANDOM_SECRET_KEY_64_CHARS

# CORS (séparés par virgule)
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend
REACT_APP_API_URL=http://localhost:8000

# Redis
REDIS_URL=redis://redis:6379

# Scraping (délais en secondes)
SCRAPING_DELAY_MIN=1.5
SCRAPING_DELAY_MAX=4.0
MAX_RETRIES=3
CONCURRENT_SCRAPERS=3

# Cron jobs (heure UTC du scraping automatique)
SCRAPING_CRON_HOUR=2
SCRAPING_CRON_MINUTE=0
