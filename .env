# ============================================
# PARABENCH - Configuration Environnement
# ============================================

# Base de données PostgreSQL
POSTGRES_DB=parabench
POSTGRES_USER=parabench
POSTGRES_PASSWORD=parabench2024_secure

# Backend
SECRET_KEY=parabench_secret_key_change_in_production_2024
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend
REACT_APP_API_URL=http://localhost:8000

# Redis
REDIS_URL=redis://redis:6379

# Scraping
SCRAPING_DELAY_MIN=2
SCRAPING_DELAY_MAX=5
MAX_RETRIES=3
CONCURRENT_SCRAPERS=3

# Cron Jobs (heure de scraping automatique)
SCRAPING_CRON_HOUR=2
SCRAPING_CRON_MINUTE=0
